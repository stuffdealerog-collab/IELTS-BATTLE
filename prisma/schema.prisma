generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model TelegramUser {
  id           String    @id @default(cuid())
  telegramId   BigInt    @unique
  username     String?
  firstName    String?
  lastName     String?
  photoUrl     String?
  languageCode String?
  role         String    @default("STUDENT") // STUDENT | TEACHER
  rating       Int       @default(1200)
  wins         Int       @default(0)
  losses       Int       @default(0)
  draws        Int       @default(0)
  xp           Int       @default(0)
  streak       Int       @default(0)
  lastActiveAt DateTime?
  currentBand  Float?    // estimated from placement test / battle history
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  essays                Essay[]
  participations        BattleParticipant[]
  lessonProgress        LessonProgress[]
  classroomsTeaching    Classroom[]         @relation("teaching")
  classroomMemberships  ClassroomMember[]
  teacherNotes          TeacherNote[]       @relation("notes_written")
  dailyChallenges       DailyChallenge[]

  @@index([rating])
  @@index([role])
}

model EssayTopic {
  id               String   @id @default(cuid())
  taskType         String
  category         String
  title            String
  prompt           String
  imageDescription String?
  createdAt        DateTime @default(now())

  essays         Essay[]
  battles        Battle[]
  lessonProgress LessonProgress[]
}

model Essay {
  id          String    @id @default(cuid())
  userId      String?
  topicId     String
  content     String    @default("")
  wordCount   Int       @default(0)
  isDraft     Boolean   @default(true)
  timeTaken   Int?
  submittedAt DateTime?
  aiScore     Float?    // 0-10, higher = more likely AI
  aiVerdict   String?   // LIKELY_HUMAN | UNCERTAIN | LIKELY_AI
  aiFlags     String?   // JSON string[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user         TelegramUser?  @relation(fields: [userId], references: [id])
  topic        EssayTopic     @relation(fields: [topicId], references: [id])
  feedback     Feedback?
  teacherNotes TeacherNote[]

  @@index([userId])
}

model Feedback {
  id               String   @id @default(cuid())
  essayId          String   @unique
  taskAchievement  Float
  coherence        Float
  lexical          Float
  grammar          Float
  overallBand      Float
  detailedFeedback String
  createdAt        DateTime @default(now())

  essay Essay @relation(fields: [essayId], references: [id])
}

model Battle {
  id          String    @id @default(cuid())
  topicId     String
  mode        String
  partType    String?
  status      String    @default("WAITING")
  timeLimit   Int
  startedAt   DateTime?
  endedAt     DateTime?
  winnerId    String?
  isBotBattle Boolean   @default(false)
  botBand     Float?    // bot difficulty: 5.0 - 8.0
  botEssay    String?   // AI-generated bot essay content
  botScore    Float?    // bot's band score
  createdAt   DateTime  @default(now())

  topic        EssayTopic          @relation(fields: [topicId], references: [id])
  participants BattleParticipant[]

  @@index([status])
}

model BattleParticipant {
  id              String    @id @default(cuid())
  battleId        String
  userId          String
  content         String    @default("")
  wordCount       Int       @default(0)
  submittedAt     DateTime?
  bandScore       Float?
  taskAchievement Float?
  coherence       Float?
  lexical         Float?
  grammar         Float?
  speedBonus      Float?
  finalScore      Float?
  ratingBefore    Int?
  ratingDelta     Int?
  feedbackJson    String?
  aiScore         Float?
  aiVerdict       String?

  battle Battle       @relation(fields: [battleId], references: [id])
  user   TelegramUser @relation(fields: [userId], references: [id])

  @@unique([battleId, userId])
  @@index([userId])
}

model MatchmakingQueue {
  id         String   @id @default(cuid())
  userId     String   @unique
  mode       String
  taskType   String
  partType   String?
  rating     Int
  enqueuedAt DateTime @default(now())

  @@index([mode, taskType, rating])
}

// ── Teacher System ───────────────────────────────────────────────────────────

model Classroom {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  teacherId   String
  description String?
  createdAt   DateTime @default(now())

  teacher TelegramUser      @relation("teaching", fields: [teacherId], references: [id])
  members ClassroomMember[]

  @@index([teacherId])
}

model ClassroomMember {
  id          String   @id @default(cuid())
  classroomId String
  userId      String
  joinedAt    DateTime @default(now())

  classroom Classroom    @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  user      TelegramUser @relation(fields: [userId], references: [id])

  @@unique([classroomId, userId])
  @@index([userId])
}

model TeacherNote {
  id        String   @id @default(cuid())
  teacherId String
  essayId   String?
  note      String
  createdAt DateTime @default(now())

  teacher TelegramUser @relation("notes_written", fields: [teacherId], references: [id])
  essay   Essay?       @relation(fields: [essayId], references: [id])
}

// ── Gamification ─────────────────────────────────────────────────────────────

model DailyChallenge {
  id          String    @id @default(cuid())
  userId      String
  date        String    // YYYY-MM-DD
  type        String    // WRITING_SPRINT | VOCAB | READING_SNIPPET
  prompt      String    // task text
  completed   Boolean   @default(false)
  completedAt DateTime?
  xpReward    Int       @default(50)
  createdAt   DateTime  @default(now())

  user TelegramUser @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@index([userId])
}

// ── Enhanced Lessons ─────────────────────────────────────────────────────────

model Lesson {
  id          String   @id @default(cuid())
  taskType    String
  category    String
  title       String
  description String
  order       Int
  createdAt   DateTime @default(now())

  steps    LessonStep[]
  progress LessonProgress[]
}

model LessonStep {
  id                 String  @id @default(cuid())
  lessonId           String
  order              Int
  partType           String
  title              String
  instruction        String
  evaluationCriteria String
  starter            String?
  vocabBank          String? // JSON: [{word, definition, example}]
  grammarTip         String? // specific grammar tip for this section
  modelAnswer        String? // example answer shown after passing

  lesson Lesson @relation(fields: [lessonId], references: [id])

  @@unique([lessonId, order])
}

model LessonProgress {
  id          String    @id @default(cuid())
  userId      String
  lessonId    String
  topicId     String?
  currentStep Int       @default(0)
  completed   Boolean   @default(false)
  essayDraft  String    @default("")
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  user   TelegramUser @relation(fields: [userId], references: [id])
  lesson Lesson       @relation(fields: [lessonId], references: [id])
  topic  EssayTopic?  @relation(fields: [topicId], references: [id])

  @@unique([userId, lessonId])
}
