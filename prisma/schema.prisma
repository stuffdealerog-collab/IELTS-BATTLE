generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model TelegramUser {
  id           String   @id @default(cuid())
  telegramId   BigInt   @unique
  username     String?
  firstName    String?
  lastName     String?
  photoUrl     String?
  languageCode String?
  rating       Int      @default(1200)
  wins         Int      @default(0)
  losses       Int      @default(0)
  draws        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  essays         Essay[]
  participations BattleParticipant[]
  lessonProgress LessonProgress[]

  @@index([rating])
}

model EssayTopic {
  id               String   @id @default(cuid())
  taskType         String
  category         String
  title            String
  prompt           String
  imageDescription String?
  createdAt        DateTime @default(now())

  essays          Essay[]
  battles         Battle[]
  lessonProgress  LessonProgress[]
}

model Essay {
  id          String     @id @default(cuid())
  userId      String?
  topicId     String
  content     String     @default("")
  wordCount   Int        @default(0)
  isDraft     Boolean    @default(true)
  timeTaken   Int?
  submittedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user     TelegramUser? @relation(fields: [userId], references: [id])
  topic    EssayTopic    @relation(fields: [topicId], references: [id])
  feedback Feedback?

  @@index([userId])
}

model Feedback {
  id               String   @id @default(cuid())
  essayId          String   @unique
  taskAchievement  Float
  coherence        Float
  lexical          Float
  grammar          Float
  overallBand      Float
  detailedFeedback String
  createdAt        DateTime @default(now())

  essay Essay @relation(fields: [essayId], references: [id])
}

model Battle {
  id        String    @id @default(cuid())
  topicId   String
  mode      String
  partType  String?
  status    String    @default("WAITING")
  timeLimit Int
  startedAt DateTime?
  endedAt   DateTime?
  winnerId  String?
  createdAt DateTime  @default(now())

  topic        EssayTopic          @relation(fields: [topicId], references: [id])
  participants BattleParticipant[]

  @@index([status])
}

model BattleParticipant {
  id              String    @id @default(cuid())
  battleId        String
  userId          String
  content         String    @default("")
  wordCount       Int       @default(0)
  submittedAt     DateTime?
  bandScore       Float?
  taskAchievement Float?
  coherence       Float?
  lexical         Float?
  grammar         Float?
  speedBonus      Float?
  finalScore      Float?
  ratingBefore    Int?
  ratingDelta     Int?
  feedbackJson    String?

  battle Battle       @relation(fields: [battleId], references: [id])
  user   TelegramUser @relation(fields: [userId], references: [id])

  @@unique([battleId, userId])
  @@index([userId])
}

model MatchmakingQueue {
  id         String   @id @default(cuid())
  userId     String   @unique
  mode       String
  taskType   String
  partType   String?
  rating     Int
  enqueuedAt DateTime @default(now())

  @@index([mode, taskType, rating])
}

model Lesson {
  id          String   @id @default(cuid())
  taskType    String
  category    String
  title       String
  description String
  order       Int
  createdAt   DateTime @default(now())

  steps    LessonStep[]
  progress LessonProgress[]
}

model LessonStep {
  id                 String @id @default(cuid())
  lessonId           String
  order              Int
  partType           String
  title              String
  instruction        String
  evaluationCriteria String
  starter            String?

  lesson Lesson @relation(fields: [lessonId], references: [id])

  @@unique([lessonId, order])
}

model LessonProgress {
  id          String    @id @default(cuid())
  userId      String
  lessonId    String
  topicId     String?
  currentStep Int       @default(0)
  completed   Boolean   @default(false)
  essayDraft  String    @default("")
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  user   TelegramUser @relation(fields: [userId], references: [id])
  lesson Lesson       @relation(fields: [lessonId], references: [id])
  topic  EssayTopic?  @relation(fields: [topicId], references: [id])

  @@unique([userId, lessonId])
}
