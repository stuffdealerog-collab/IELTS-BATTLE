# Database (SQLite for dev — replace with hosted DB for production)
DATABASE_URL="file:./prisma/dev.db"

# Anthropic API — get key at https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."

# Telegram Bot — create via @BotFather → /newbot → /newapp
TELEGRAM_BOT_TOKEN=""

# JWT — generate with: openssl rand -base64 32
JWT_SECRET=""

# Pusher Channels — sign up at pusher.com (free tier)
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER="eu"

# Public Pusher config (exposed to client)
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER="eu"
